{
  "name": "opensymphony-frontend",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "type-check": "tsc --build tsconfig.projects.json",
    "lint": "echo 'ESLint configured; run npx eslint apps/ packages/ to check'",
    "test": "npm run build --workspace=@opensymphony/web && jest --config jest.config.js",
    "clean": "rm -rf apps/*/dist packages/*/dist"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
